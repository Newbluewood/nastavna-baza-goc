{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node server.js",
    "dev": "npm run start:win",
    "start:win": "powershell -NoProfile -Command \"$p=(Get-NetTCPConnection -LocalPort 3000 -State Listen -ErrorAction SilentlyContinue | Select-Object -First 1 -ExpandProperty OwningProcess); if($p){Stop-Process -Id $p -Force}; Set-Location .; node server.js\"",
    "db:init:dry": "node scripts/InitialConfigDB.js",
    "db:init:run": "node scripts/InitialConfigDB.js --execute",
    "migrate:dry": "node migrateDb.js",
    "migrate:run": "node migrateDb.js --execute",
    "db:seed:presentation:dry": "node presentationDBmockData.js",
    "db:seed:presentation:run": "node presentationDBmockData.js --execute",
    "db:sanity": "node dbSanityCheck.js",
    "smoke:routes": "node tests/smokeTestRoutes.js",
    "smoke:write-flow": "node tests/smokeTestWriteFlow.js",
    "smoke:all": "npm.cmd run smoke:routes && npm.cmd run smoke:write-flow",
    "test": "jest",
    "restart-site": "node resetSite.js",
    "restart-site:run": "node resetSite.js --execute",
    "restart-site:full": "node resetSite.js --execute --smoke",
    "seed:site-kb": "node scripts/seed-site-kb.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@qdrant/js-client-rest": "^1.17.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dayjs": "^1.11.10",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "handlebars": "^4.7.8",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "mysql2": "^3.22.0",
    "node-fetch": "^2.7.0",
    "nodemailer": "^8.0.5",
    "openai": "^6.34.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "supertest": "^7.2.2"
  }
}
