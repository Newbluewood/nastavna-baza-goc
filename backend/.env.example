# --- Database (MySQL) ---
# Production (Aiven / Render): prefer a single URI from the Aiven console.
# Example (password must be URL-encoded if it has special chars):
# DATABASE_URL=mysql://USER:PASSWORD@HOST:PORT/defaultdb?ssl-mode=REQUIRED
#
# If DATABASE_URL is set, DB_HOST / DB_USER / DB_PASSWORD / DB_NAME / DB_PORT are ignored for connections.
DATABASE_URL=

# Local or split vars (used only when DATABASE_URL is empty)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=baza_goc
DB_PORT=3306
# Force TLS (optional; also auto-enabled for *.aivencloud.com when using DB_* vars)
DB_SSL=false

# Pool size for the API (`db.js`)
DB_POOL_SIZE=10

PORT=3000

# JWT Secrets (CHANGE THESE IN PRODUCTION!)
JWT_SECRET=baza_goc_super_secret_key_123
GUEST_JWT_SECRET=guest_secret_change_in_production

# Email
EMAIL_USER=your_email@gmail.com
EMAIL_APP_PASSWORD=your_app_password
EMAIL_FROM=your_email@gmail.com
EMAIL_REPLY_TO=your_email@gmail.com
BREVO_API_KEY=your_brevo_api_key

# Frontend URL
FRONTEND_URL=https://your-frontend-url.netlify.app

# CORS
ALLOWED_ORIGINS=https://your-frontend-url.netlify.app,http://localhost:3001

# Seed / Smoke Test
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_PASSWORD=admin123
SMOKE_BASE_URL=http://127.0.0.1:3000

DEEPL_API_KEY=your_deepl_key_here

# AI (Graceful Degradation)
AI_ENABLED=false
AI_PROVIDER=mock
AI_API_KEY=
AI_MODEL=claude-sonnet-4-6
AI_RATE_LIMIT_ENABLED=true
AI_MAX_REQUESTS_PER_MINUTE_GLOBAL=20
AI_MAX_REQUESTS_PER_USER_PER_HOUR=60
AI_MAX_REQUESTS_PER_DAY_GLOBAL=500
AI_BUDGET_FAIL_OPEN=false
AI_MAX_INPUT_WORDS=100
AI_MAX_INPUT_CHARS=700
AI_MAX_OUTPUT_WORDS=80
AI_MAX_OUTPUT_TOKENS=180
AI_CHAT_ASSISTANT_ENABLED=true
AI_CHAT_MAX_WORDS=45
AI_CHAT_MAX_CHARS=420
AI_CHAT_MAX_OUTPUT_TOKENS=120
AI_CHAT_USE_LIVE_FOR_NEEDS_INPUT=false
AI_CHAT_USE_LIVE_INTENT=true
AI_CHAT_CACHE_TTL_MS=300000
AI_CHAT_CACHE_MAX_ENTRIES=300
AI_CHAT_CONTEXT_GUARD_ENABLED=true
AI_CHAT_OOD_WARN_THRESHOLD=3
AI_CHAT_OOD_STRICT_THRESHOLD=5
AI_CHAT_OOD_LOCK_THRESHOLD=8
AI_CHAT_OOD_LOCK_MS=7200000
AI_CHAT_OOD_DECAY_MS=21600000
AI_CHAT_CONTEXT_GUARD_MAX_ENTRIES=3000
GOC_DESTINATION_LABEL=Nastavna baza Goc
GOC_DESTINATION_LAT=43.559095
GOC_DESTINATION_LON=20.75393

# Weather (Open-Meteo)
WEATHER_LAT=43.559095
WEATHER_LON=20.75393
WEATHER_TIMEZONE=Europe/Belgrade

# --- Render / production: paste secrets below (vector + embeddings) ---
# Leave USE_VECTOR_SEARCH=false on Render unless you host Qdrant + matching index.
USE_VECTOR_SEARCH=false
# Qdrant Cloud: cluster "Endpoint" / URL → QDRANT_URL; dashboard API key → QDRANT_API_KEY (omit for local Docker)
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=facts_collection
EMBEDDING_PROVIDER=gemini
EMBEDDING_SERVICE_URL=http://127.0.0.1:8000/embed
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_OUTPUT_DIM=
# HuggingFace (site-guide / optional embeddings): requires HUGGINGFACE_API_KEY when EMBEDDING_PROVIDER=huggingface
# HUGGINGFACE_API_KEY=
# HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Base URL for HF or local when not using full EMBEDDING_SERVICE_URL (local FastAPI)
# EMBEDDING_URL=http://127.0.0.1:8000
# EMBEDDING_TIMEOUT_MS=3000
# EMBEDDING_RETRY_COUNT=1
